# Required: KIE.AI for all AI generation (Nano Banana Pro images, Kling 2.6 video, Gemini text, ElevenLabs TTS)
# Get at: https://kie.ai/api-key
KIE_AI_API_KEY=

# Required for production: change for HMAC signing of session tokens
SESSION_SECRET=change-this-in-production-please

# Optional (we route through Kie AI by default)
ELEVENLABS_API_KEY=

# Server port (auto-injected by Render / Railway / Fly.io)
# PORT=8766
